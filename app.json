{
  "expo": {
    "name": "Razorbook Reach Intake",
    "slug": "razorbook-reach-intake",
    "scheme": "razorbookreachintake",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.razorbook.reachintake",
      "infoPlist": {
        "NSCameraUsageDescription": "Razorbook Reach Intake uses the camera to scan ISBN barcodes."
      }
    },
    "android": {
      "package": "com.razorbook.reachintake",
      "permissions": [
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

